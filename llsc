local camera = game.Workspace.CurrentCamera
local smooth = 0.25

Rb:Connect(function()
	if _G.HighLightInWorld == true then
		local CK = game:GetService("Lighting"):FindFirstChild("Clouded Sky")
		if CK then 
			CK.Parent = workspace
		end
		Lighting.ClockTime = 14.5
		Lighting.Brightness = 3
	else
		if workspace:FindFirstChild("Clouded Sky") then
			workspace:FindFirstChild("Clouded Sky").Parent = game:GetService("Lighting")
		end
	end

	if _G.IsAimbot == true then

		local localchar = plrchars:WaitForChild(localplr.Name)
		local localPos = Vector3.new(0,0,0)
		if localchar then
			local LocalHumRootPart = localchar:FindFirstChild("HumanoidRootPart")

			if LocalHumRootPart then
				localPos = LocalHumRootPart.Position
			end
		end




		local closest = nil
		local minDist = math.huge
		local mousePos = UserInputService:GetMouseLocation()

		for _,v in plrchars:GetChildren() do
			
			if v:IsA("Model") and v ~= localchar and v and v:FindFirstChild("Head") then
			
				local char = v
				if not char 
					or not char:FindFirstChild("Head") 
					or not char:FindFirstChildOfClass("Humanoid") 
					or char.Humanoid.Health <= 0 then
					
					continue
				end
				local tgplr = plrs:FindFirstChild(v.Name)
				if not tgplr and not game:GetService("RunService"):IsStudio() then
		
					continue
				end
				if _G.TeamCheck == true then
					if localplr:GetAttribute("Team") ~= nil and tgplr:GetAttribute("Team") == localplr:GetAttribute("Team") then
					
						continue
					end
				end



				local targetPos = char.HumanoidRootPart.Position

				local distanceBetweenPlayers = (targetPos - localPos).Magnitude
				if distanceBetweenPlayers > 2000 then
			
					continue
				end


				local head = v.HumanoidRootPart
			
				local forwardPos = head.Position + head.CFrame.LookVector * offsetValue
		
				local pos, onScreen = camera:WorldToViewportPoint(forwardPos)
				if onScreen then
					local dist = (Vector2.new(pos.X, pos.Y) - mousePos).Magnitude
					if dist < minDist then
						minDist = dist
						closest = pos
					end
				end
			end
		end

		if closest then
		
			
			local tx = closest.X - mousePos.X
			local ty = closest.Y - mousePos.Y
		
			if not game:GetService("RunService"):IsStudio() then
				mousemoverel(tx * smooth, ty * smooth)
			end
		end
	end

	if _G.HighLightInPlrChar then
		for _, v3 in ipairs(plrchars:GetChildren()) do
			if v3:IsA("Model") and v3.Name ~= localplr.Name then
				if not v3:FindFirstChild("HGH") then
					local new = Instance.new("Highlight",v3)
					new.Name = "HGH"
				end
			end
		end
	else
		for _, v3 in ipairs(plrchars:GetChildren()) do
			if v3:IsA("Model") then
				if v3:FindFirstChild("HGH") then
					v3:FindFirstChild("HGH"):Destroy()
				end
			end
		end
	end
end)
