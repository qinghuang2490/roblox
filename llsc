function CreateButton(Text,Type,Click)
	local newbutton = Instance.new("Frame",ScrollingFrame)
	newbutton.Size = UDim2.new(1,0,.07,0)
	newbutton.Transparency = .5
	local UIGradient = Instance.new("UIGradient",newbutton)
	UIGradient.Color = ColorSequence.new({
		ColorSequenceKeypoint.new(0,Color3.fromRGB(0, 0, 0)),
		ColorSequenceKeypoint.new(1,Color3.fromRGB(0, 0, 0))
	})
	UIGradient.Transparency = NumberSequence.new({
		NumberSequenceKeypoint.new(0,0),
		NumberSequenceKeypoint.new(1,1)
	})
	local textlabel = Instance.new("TextLabel",newbutton)
	textlabel.Text = Text
	textlabel.BackgroundTransparency = 1
	textlabel.TextScaled = true
	textlabel.TextColor3 = Color3.fromRGB(255, 255, 255)
	textlabel.TextStrokeTransparency = .8
	textlabel.Size = UDim2.new(.9, 0,0.6, 0)
	textlabel.AnchorPoint = Vector2.new(0.5,0.5)
	textlabel.Position = UDim2.new(0.5, 0,0.5, 0)
	textlabel.TextXAlignment = Enum.TextXAlignment.Left
	if Type == "Boolean" then
		textlabel.Text = Text.." [OFF]"
	elseif Type == "Number" then
		local textbox = Instance.new("TextBox",newbutton)
		textbox.Size = UDim2.new(.9, 0,0.6, 0)
		textbox.AnchorPoint = Vector2.new(0.5,0.5)
		textbox.Position = UDim2.new(0.5, 0,0.5, 0)
		textbox.Text = ""
		textbox.TextColor3 = Color3.fromRGB(255, 255, 255)
		textbox.TextStrokeTransparency = .8
		textbox.TextXAlignment = Enum.TextXAlignment.Right
		textbox.TextScaled = true
		textbox.BackgroundTransparency = 1
		textbox:GetPropertyChangedSignal("Text"):Connect(function()
			if Text== "Offset" then
				if tostring(textbox.Text) == nil then
					offsetValue = 1
				else
					offsetValue = tostring(textbox.Text)
				end
					
			end
		end)
	end
	local bt = Instance.new("TextButton",newbutton)
	bt.Size = UDim2.new(1,0,1,0)
	bt.BackgroundTransparency = 1
	bt.Text = ""
	bt.MouseButton1Click:Connect(function()
		Click(newbutton)
	end)
	if Type == "Number" then
		bt.Visible = false
	end

end

