local function getCharacter()
    return player.Character
end

local function getHumanoid()
    local char = getCharacter()
    return char and char:FindFirstChild("Humanoid")
end

local function getRootPart()
    local char = getCharacter()
    return char and char:FindFirstChild("HumanoidRootPart")
end

local respawnConnection
local function startRespawn(interval)
    if respawnConnection then
        respawnConnection:Disconnect()
        respawnConnection = nil
    end
    respawnConnection = RunService.Heartbeat:Connect(function()
        local hum = getHumanoid()
        if hum and hum.Health > 0 then
            hum.Health = 0
        end
        task.wait(interval)
    end)
end

local teleportConnection
local function startTeleport(interval)
    if teleportConnection then
        teleportConnection:Disconnect()
        teleportConnection = nil
    end
    teleportConnection = RunService.Heartbeat:Connect(function()
        local root = getRootPart()
        if root then
            local offset = Vector3.new(
                math.random(-200, 200),
                0,
                math.random(-200, 200)
            )
            root.CFrame = root.CFrame + offset
        end
        task.wait(interval)
    end)
end

local shakeConnection
local function startScreenShake(intensity)
    if shakeConnection then
        shakeConnection:Disconnect()
        shakeConnection = nil
    end
    local camera = workspace.CurrentCamera
    shakeConnection = RunService.RenderStepped:Connect(function()
        if camera then
            local shakeX = math.random(-intensity * 2, intensity * 2) / 10
            local shakeY = math.random(-intensity * 2, intensity * 2) / 10
            local shakeZ = math.random(-intensity, intensity) / 20
            camera.CFrame = camera.CFrame * CFrame.Angles(shakeX, shakeY, shakeZ)
        end
    end)
end

